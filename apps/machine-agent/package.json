{
  "name": "@print-karo/machine-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Print Karo Windows Machine Agent — turns a PC into a vending machine. Hardware-agnostic core; Raspberry Pi reuses the same core via a different printer adapter.",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "electron .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@print-karo/types": "workspace:*",
    "systeminformation": "^5.23.5"
  },
  "devDependencies": {
    "@print-karo/config-eslint": "workspace:*",
    "@print-karo/config-tsconfig": "workspace:*",
    "@types/node": "^22.10.5",
    "electron": "^33.2.1",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
