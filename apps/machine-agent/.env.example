# Print Karo Machine Agent — runtime config.
# In production these come from the OS keystore (provisioned once).
PK_API_BASE_URL="https://printkaro-b9r0.onrender.com"
PK_MACHINE_ID="<machine-uuid-from-registration>"
PK_MACHINE_SECRET="<one-time-secret-from-registration>"

# Cadences (seconds) — the server may override these via GET /machine/config.
PK_HEARTBEAT_INTERVAL_SEC=30
PK_QUEUE_POLL_INTERVAL_SEC=15
PK_LOG_UPLOAD_INTERVAL_SEC=60

# Reconnect backoff (ms)
PK_RECONNECT_BASE_MS=1000
PK_RECONNECT_MAX_MS=30000

# Force a printer adapter (windows | cups | simulator). Auto-detected if unset.
# PK_PRINTER_ADAPTER=simulator
