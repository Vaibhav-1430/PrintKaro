generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  name                String?
  emailVerified       Boolean          @default(false)
  image               String?
  role                Role             @default(CUSTOMER)
  status              UserStatus       @default(ACTIVE)
  isActive            Boolean          @default(true)
  createdById         String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  deletedAt           DateTime?
  phoneNumber         String?          @unique
  phoneNumberVerified Boolean          @default(false)
  accounts            Account[]
  adminProfile        AdminProfile?
  auditLogs           AuditLog[]       @relation("ActorAudit")
  customerProfile     CustomerProfile?
  notifications       Notification[]
  operatorProfile     OperatorProfile?
  orders              Order[]
  sessions            Session[]
  createdBy           User?            @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers        User[]           @relation("UserCreator")

  @@index([role])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id             String    @id @default(uuid())
  userId         String
  token          String    @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  deviceType     String?
  browser        String?
  os             String?
  country        String?
  fingerprint    String?
  lastActivityAt DateTime  @default(now())
  revoked        Boolean   @default(false)
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([revoked])
  @@index([expiresAt])
  @@map("sessions")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  roles       RolePermission[]

  @@index([deletedAt])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  role         Role
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@map("role_permissions")
}

model CustomerProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  phone       String?
  defaultCity String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]
  uploads     Upload[]

  @@map("customer_profiles")
}

model OperatorProfile {
  id           String    @id @default(uuid())
  userId       String    @unique
  businessName String
  contactPhone String?
  payoutVpa    String?
  approved     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  machines     Machine[]
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([approved])
  @@map("operator_profiles")
}

model AdminProfile {
  id           String    @id @default(uuid())
  userId       String    @unique
  department   String?
  isSuperAdmin Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model Machine {
  id                String                @id @default(uuid())
  code              String                @unique
  name              String
  status            MachineStatus         @default(PROVISIONING)
  type              MachineType           @default(WINDOWS)
  college           String?
  building          String?
  floor             String?
  room              String?
  latitude          Float?
  longitude         Float?
  operatorProfileId String?
  lastAuthAt        DateTime?
  lastHeartbeatAt   DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  deletedAt         DateTime?
  capabilities      MachineCapabilities?
  configuration     MachineConfiguration?
  credential        MachineCredential?
  health            MachineHealth?
  heartbeats        MachineHeartbeat[]
  logs              MachineLog[]
  network           MachineNetwork?
  printer           MachinePrinter?
  machineProfile    MachineProfile?
  operatorProfile   OperatorProfile?      @relation(fields: [operatorProfileId], references: [id])
  orders            Order[]
  pins              Pin[]
  pricingRules      PricingRule[]
  printJobs         PrintJob[]
  refreshTokens     RefreshToken[]

  @@index([status])
  @@index([type])
  @@index([operatorProfileId])
  @@index([college])
  @@index([lastHeartbeatAt])
  @@index([deletedAt])
  @@map("machines")
}

model MachineProfile {
  id            String    @id @default(uuid())
  machineId     String    @unique
  locationLabel String?
  latitude      Float?
  longitude     Float?
  platform      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  machine       Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("machine_profiles")
}

model MachineCredential {
  id         String    @id @default(uuid())
  machineId  String    @unique
  secretHash String
  rotatedAt  DateTime  @default(now())
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  machine    Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("machine_credentials")
}

model MachineCapabilities {
  id            String    @id @default(uuid())
  machineId     String    @unique
  colorSupport  Boolean   @default(false)
  duplexSupport Boolean   @default(false)
  paperSizes    String[]  @default(["A4"])
  maxCopies     Int       @default(50)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  machine       Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("machine_capabilities")
}

model MachinePrinter {
  id              String       @id @default(uuid())
  machineId       String       @unique
  printerName     String?
  isDefault       Boolean      @default(false)
  state           PrinterState @default(UNKNOWN)
  paperRemaining  Int?
  paperSize       String?
  colorAvailable  Boolean      @default(false)
  duplexAvailable Boolean      @default(false)
  inkLevel        Int?
  tonerLevel      Int?
  errorCode       String?
  updatedAt       DateTime     @updatedAt
  createdAt       DateTime     @default(now())
  machine         Machine      @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("machine_printers")
}

model MachineNetwork {
  id             String   @id @default(uuid())
  machineId      String   @unique
  online         Boolean  @default(false)
  internet       Boolean  @default(false)
  ipAddress      String?
  connection     String?
  signalStrength Int?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
  machine        Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("machine_networks")
}

model MachineConfiguration {
  id                   String    @id @default(uuid())
  machineId            String    @unique
  heartbeatIntervalSec Int       @default(30)
  queuePollIntervalSec Int       @default(15)
  logUploadIntervalSec Int       @default(60)
  maintenanceMode      Boolean   @default(false)
  settings             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?
  machine              Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("machine_configurations")
}

model MachineHeartbeat {
  id              String              @id @default(uuid())
  machineId       String
  runtimeState    MachineRuntimeState
  printerState    PrinterState        @default(UNKNOWN)
  printerName     String?
  cpuUsage        Float?
  ramUsage        Float?
  diskUsage       Float?
  temperature     Float?
  networkOnline   Boolean             @default(false)
  internet        Boolean             @default(false)
  paperRemaining  Int?
  paperSize       String?
  colorAvailable  Boolean             @default(false)
  duplexAvailable Boolean             @default(false)
  inkLevel        Int?
  tonerLevel      Int?
  currentJobId    String?
  errorCode       String?
  reportedAt      DateTime
  createdAt       DateTime            @default(now())
  machine         Machine             @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId, createdAt])
  @@index([createdAt])
  @@map("machine_heartbeats")
}

model MachineHealth {
  id               String              @id @default(uuid())
  machineId        String              @unique
  runtimeState     MachineRuntimeState @default(OFFLINE)
  printerState     PrinterState        @default(UNKNOWN)
  healthScore      Int                 @default(0)
  gateResult       HealthGateResult    @default(BLOCKED)
  blockingReasons  String[]            @default([])
  printerConnected Boolean             @default(false)
  paperAvailable   Boolean             @default(false)
  consumablesOk    Boolean             @default(false)
  internet         Boolean             @default(false)
  heartbeatFresh   Boolean             @default(false)
  cpuUsage         Float?
  ramUsage         Float?
  diskUsage        Float?
  temperature      Float?
  lastHeartbeatAt  DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  machine          Machine             @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([gateResult])
  @@index([runtimeState])
  @@map("machine_health")
}

model MachineLog {
  id            String          @id @default(uuid())
  machineId     String
  level         MachineLogLevel @default(INFO)
  event         MachineLogEvent
  message       String?
  context       Json?
  correlationId String?
  occurredAt    DateTime
  createdAt     DateTime        @default(now())
  machine       Machine         @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId, createdAt])
  @@index([event, createdAt])
  @@index([level])
  @@map("machine_logs")
}

model RefreshToken {
  id           String         @id @default(uuid())
  machineId    String
  tokenHash    String         @unique
  replacedById String?
  expiresAt    DateTime
  revoked      Boolean        @default(false)
  revokedAt    DateTime?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  machine      Machine        @relation(fields: [machineId], references: [id], onDelete: Cascade)
  replacedBy   RefreshToken?  @relation("TokenRotation", fields: [replacedById], references: [id])
  rotatedFrom  RefreshToken[] @relation("TokenRotation")

  @@index([machineId])
  @@index([revoked])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id             String      @id @default(uuid())
  action         AuditAction
  actorUserId    String?
  actorType      String      @default("USER")
  actorMachineId String?
  targetType     String?
  targetId       String?
  ipAddress      String?
  userAgent      String?
  correlationId  String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  actor          User?       @relation("ActorAudit", fields: [actorUserId], references: [id])

  @@index([action, createdAt])
  @@index([actorUserId])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

model Upload {
  id                String          @id @default(uuid())
  customerProfileId String
  storageKey        String          @unique
  originalKey       String?
  originalFilename  String
  mimeType          String
  sizeBytes         Int
  sha256            String
  status            UploadStatus    @default(PENDING)
  virusScanClean    Boolean         @default(true)
  rejectionReason   String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  metadata          FileMetadata?
  orders            Order[]
  customerProfile   CustomerProfile @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)

  @@index([customerProfileId])
  @@index([sha256])
  @@index([status])
  @@index([deletedAt])
  @@map("uploads")
}

model FileMetadata {
  id                    String   @id @default(uuid())
  uploadId              String   @unique
  pageCount             Int
  isColor               Boolean  @default(false)
  orientation           String   @default("portrait")
  paperSize             String   @default("A4")
  estimatedPrintSeconds Int      @default(0)
  widthPt               Float?
  heightPt              Float?
  encrypted             Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  upload                Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@map("file_metadata")
}

model Order {
  id                String          @id @default(uuid())
  orderNumber       String          @unique
  customerProfileId String
  userId            String
  uploadId          String
  machineId         String
  status            OrderStatus     @default(DRAFT)
  amountPaise       Int             @default(0)
  currency          String          @default("INR")
  failureReason     String?
  paidAt            DateTime?
  printedAt         DateTime?
  completedAt       DateTime?
  expiresAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  customerProfile   CustomerProfile @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  machine           Machine         @relation(fields: [machineId], references: [id])
  upload            Upload          @relation(fields: [uploadId], references: [id])
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment           Payment?
  pin               Pin?
  printJob          PrintJob?
  printOption       PrintOption?
  receipt           Receipt?

  @@index([customerProfileId, status])
  @@index([machineId, status])
  @@index([status, createdAt])
  @@index([deletedAt])
  @@map("orders")
}

model PrintOption {
  id           String   @id @default(uuid())
  orderId      String   @unique
  copies       Int      @default(1)
  colorMode    String   @default("BW")
  duplex       Boolean  @default(false)
  paperSize    String   @default("A4")
  orientation  String   @default("portrait")
  pageRange    String?
  pagesToPrint Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("print_options")
}

model Payment {
  id                String        @id @default(uuid())
  orderId           String        @unique
  provider          String        @default("simulator")
  status            PaymentStatus @default(PENDING)
  amountPaise       Int
  currency          String        @default("INR")
  providerOrderId   String?
  providerPaymentId String?
  failureReason     String?
  refundedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactions      Transaction[]

  @@index([status])
  @@index([orderId])
  @@map("payments")
}

model Transaction {
  id          String        @id @default(uuid())
  paymentId   String
  type        String        @default("CHARGE")
  result      PaymentResult
  providerRef String?
  amountPaise Int
  rawResponse Json?
  createdAt   DateTime      @default(now())
  payment     Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([result])
  @@map("transactions")
}

model Pin {
  id          String    @id @default(uuid())
  orderId     String    @unique
  machineId   String
  codeHash    String
  status      PinStatus @default(ACTIVE)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  expiresAt   DateTime
  redeemedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  machine     Machine   @relation(fields: [machineId], references: [id])
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([machineId, status])
  @@index([status, expiresAt])
  @@index([orderId])
  @@map("pins")
}

model Receipt {
  id            String   @id @default(uuid())
  orderId       String   @unique
  receiptNumber String   @unique
  amountPaise   Int
  currency      String   @default("INR")
  storageKey    String?
  issuedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("receipts")
}

model PrintJob {
  id            String         @id @default(uuid())
  orderId       String         @unique
  machineId     String
  status        PrintJobStatus @default(QUEUED)
  attempts      Int            @default(0)
  maxAttempts   Int            @default(3)
  lockToken     String?
  claimedAt     DateTime?
  lockedUntil   DateTime?
  dispatchedAt  DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  failedAt      DateTime?
  failureReason String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  machine       Machine        @relation(fields: [machineId], references: [id])
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([machineId, status])
  @@index([status, lockedUntil])
  @@index([orderId])
  @@map("print_jobs")
}

model Notification {
  id        String              @id @default(uuid())
  userId    String
  orderId   String?
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  read      Boolean             @default(false)
  sentAt    DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([type])
  @@map("notifications")
}

model PricingRule {
  id                String    @id @default(uuid())
  machineId         String?
  paperSize         String    @default("A4")
  bwPerPagePaise    Int       @default(200)
  colorPerPagePaise Int       @default(1000)
  duplexDiscountPct Int       @default(0)
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  machine           Machine?  @relation(fields: [machineId], references: [id])

  @@unique([machineId, paperSize])
  @@index([active])
  @@map("pricing_rules")
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

enum Role {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  CUSTOMER
  MACHINE
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum MachineStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  DECOMMISSIONED
}

enum MachineRuntimeState {
  ONLINE
  OFFLINE
  BOOTING
  IDLE
  PRINTING
  PAUSED
  ERROR
  OUT_OF_PAPER
  PAPER_JAM
  PRINTER_OFFLINE
  LOW_INK
  LOW_TONER
  MAINTENANCE
}

enum MachineType {
  WINDOWS
  RASPBERRY_PI
  INDUSTRIAL_PC
}

enum PrinterState {
  READY
  BUSY
  PAUSED
  OFFLINE
  ERROR
  UNKNOWN
}

enum HealthGateResult {
  READY
  WARNING
  BLOCKED
}

enum MachineLogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

enum MachineLogEvent {
  LOGIN
  LOGOUT
  HEARTBEAT
  PRINT_START
  PRINT_SUCCESS
  PRINT_FAILURE
  RESTART
  RECONNECT
  SHUTDOWN
  CRASH
  ERROR
  WARNING
  JOB_ACCEPTED
  JOB_REJECTED
  CONFIG_FETCHED
}

enum AuditAction {
  USER_REGISTERED
  USER_LOGIN
  USER_LOGOUT
  USER_LOGOUT_ALL
  LOGIN_FAILED
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  EMAIL_VERIFICATION_SENT
  EMAIL_VERIFIED
  PROFILE_UPDATED
  SESSION_REVOKED
  ROLE_CHANGED
  USER_SUSPENDED
  USER_REACTIVATED
  ADMIN_CREATED
  OPERATOR_CREATED
  MACHINE_CREATED
  MACHINE_LOGIN
  MACHINE_LOGOUT
  MACHINE_TOKEN_REFRESHED
  MACHINE_REVOKED
  MACHINE_REGISTERED
  MACHINE_SUSPENDED
  MACHINE_REACTIVATED
  MACHINE_RESTART_REQUESTED
  MACHINE_SECRET_ROTATED
  MACHINE_HEARTBEAT_STALE
  OAUTH_LINKED
  ORDER_CREATED
  ORDER_UPLOADED
  ORDER_VALIDATED
  ORDER_MACHINE_VERIFIED
  ORDER_PAYMENT_INITIATED
  ORDER_PAID
  ORDER_PAYMENT_FAILED
  PIN_GENERATED
  PIN_REDEEMED
  PIN_FAILED
  PIN_EXPIRED
  PRINT_DISPATCHED
  PRINT_STARTED
  PRINT_COMPLETED
  PRINT_FAILED
  ORDER_COMPLETED
  ORDER_EXPIRED
  ORDER_CANCELLED
  REFUND_ISSUED
  FILE_UPLOADED
  FILE_REJECTED
  FILE_DOWNLOADED
  PHONE_OTP_SENT
  PHONE_OTP_FAILED
  PHONE_VERIFIED
}

enum UploadStatus {
  PENDING
  UPLOADED
  CONVERTING
  VALIDATED
  REJECTED
}

enum OrderStatus {
  DRAFT
  UPLOADED
  VALIDATED
  MACHINE_READY
  PAYMENT_PENDING
  PAID
  PIN_GENERATED
  WAITING_AT_MACHINE
  PRINTING
  COMPLETED
  FAILED
  EXPIRED
  REFUNDED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentResult {
  SUCCESS
  FAILURE
  TIMEOUT
  CANCELLED
}

enum PinStatus {
  ACTIVE
  REDEEMED
  EXPIRED
  REVOKED
}

enum PrintJobStatus {
  QUEUED
  DISPATCHED
  CLAIMED
  PRINTING
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum NotificationType {
  ORDER_CREATED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  PIN_GENERATED
  PRINTING_STARTED
  PRINTING_COMPLETED
  PRINTING_FAILED
  ORDER_EXPIRED
  REFUND_ISSUED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}
