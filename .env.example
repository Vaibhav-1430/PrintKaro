# ─────────────────────────────────────────────────────────────
# Print Karo — root environment example.
# Copy to .env and fill in. NEVER commit a real .env.
# Each app/package also documents the subset it needs.
# ─────────────────────────────────────────────────────────────

# Shared
NODE_ENV=development

# ── Database (Neon / local Postgres) ──────────────────────────
# Pooled connection for the app:
DATABASE_URL="hbjnkml,"
# Direct (unpooled) connection used for migrations:
DATABASE_URL_UNPOOLED="postgresql://printkaro:printkaro@localhost:5432/printkaro?schema=public"

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Backend API (apps/api) ────────────────────────────────────
PORT=4000
API_BASE_URL="https://printkaro-b9r0.onrender.com"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002"

# ── Better Auth (packages/auth) ───────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me-with-a-32-byte-random-secret"
BETTER_AUTH_URL="https://printkaro-b9r0.onrender.com"

# ── Web apps (public — safe to expose) ────────────────────────
NEXT_PUBLIC_API_BASE_URL="https://printkaro-b9r0.onrender.com"
NEXT_PUBLIC_APP_ENV="development"
